# ===== CONFIGURACIÓN CORS =====
# Solo gateway-api (el navegador no debe llamar directo a este servicio)
CORS_ORIGINS=http://localhost:3002

# ===== CONFIGURACIÓN DE BASE DE DATOS =====
# Prioridad: DATABASE_URL (recomendado, misma BD que el resto del ERP)
DATABASE_URL=postgresql://USUARIO:PASSWORD@HOST:5432/postgres

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password_here
DB_DATABASE=postgres

# ===== CONFIGURACIÓN JWT =====
# Obligatorio. Generar: openssl rand -base64 48 (mismo valor donde se valide el mismo token)
JWT_SECRET=

# ===== CONFIGURACIÓN DEL SERVIDOR =====
PORT=3001 