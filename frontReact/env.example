# Variables de entorno para FrontReact con arquitectura híbrida

# Gateway — todas las consultas GraphQL (login, menú, terceros…). No uses el puerto 3003 desde el front.
VITE_GATEWAY_URL=http://localhost:3002

# Opcional: solo depuración directa a MenuNestJs (ej. http://localhost:3003/graphql). En producción no definir.
# VITE_MENU_GRAPHQL_URL=

# InicioPython - Para escritura de datos (REST API)
VITE_PYTHON_URL=http://localhost:5000

# Configuración de desarrollo
NODE_ENV=development
VITE_APP_TITLE=ERP System

# Opcional: mock /api/account del template (_apis_/account.js); sin esto el mock no registra rutas
# VITE_MOCK_JWT_SECRET=