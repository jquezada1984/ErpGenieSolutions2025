# ===== CONFIGURACIÓN DE SERVICIOS (OBLIGATORIAS) =====

# Servicio Python (REST) - InicioPython - OBLIGATORIO
PYTHON_SERVICE_URL=http://localhost:5000

# Servicio NestJS (GraphQL) - InicioNestJs - OBLIGATORIO
NESTJS_SERVICE_URL=http://localhost:3001

# Servicio de Menús (GraphQL) - MenuNestJs - OBLIGATORIO
MENU_SERVICE_URL=http://localhost:3003

# ===== CONFIGURACIÓN OPCIONAL =====

# production: respuestas de error genéricas al cliente (sin mensajes internos ni URLs)
# NODE_ENV=production

# Timeouts (en milisegundos)
PYTHON_SERVICE_TIMEOUT=5000
NESTJS_SERVICE_TIMEOUT=5000
GRAPHQL_SERVICE_TIMEOUT=10000

# Puerto del Gateway
GATEWAY_PORT=3002

