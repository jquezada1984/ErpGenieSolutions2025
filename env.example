# Variables de Entorno para ERP Docker (raíz del repo)
# Copiar a ".env". Docker Compose usa DATABASE_URL aquí para interpolar servicios.

# Base de datos compartida (PostgreSQL / Supabase)
DATABASE_URL=postgresql://USUARIO:PASSWORD@HOST:5432/postgres

# CORS en microservicios (Nest/Python): solo el origen del gateway (el navegador no llama directo).
# docker-compose.dev.yml inyecta esto; si personalizas, mantén solo el gateway.
CORS_ORIGINS=http://localhost:3002

# CORS del gateway-api: orígenes del navegador que cargan el frontend (Vite / Nginx).
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Para SQLite local (desarrollo):
# DATABASE_URL=sqlite:///app/data/database.db

# JWT (obligatorio para docker-compose.yml: definir antes de `docker compose up`)
# Generar: openssl rand -base64 48. Nest/Python comparten el mismo secreto.
JWT_SECRET_KEY=
JWT_SECRET=

# Servicios URLs (configurados automáticamente en Docker)
PYTHON_SERVICE_URL=http://python-service:5000
NESTJS_SERVICE_URL=http://nestjs-service:3001
MENU_SERVICE_URL=http://menu-service:3003
GATEWAY_PORT=3002

# Entornos
NODE_ENV=production
FLASK_ENV=production
