# ===== CONFIGURACIÓN CORS =====
CORS_ORIGINS=http://localhost:3002

# ===== CONFIGURACIÓN DE BASE DE DATOS =====
DATABASE_URL=postgresql://USUARIO:PASSWORD@HOST:5432/postgres

# ===== CONFIGURACIÓN JWT / Flask =====
# JWT_SECRET obligatorio (mismo que InicioNestJs). SECRET_KEY opcional si ya existe JWT_SECRET (Flask lo reutiliza).
JWT_SECRET=
SECRET_KEY=

# ===== CONFIGURACIÓN DEL SERVIDOR =====
PORT=5000 